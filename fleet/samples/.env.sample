# Hermes Agent — Sample .env
# Copy this to .env and fill in your actual API keys.
# NEVER commit this file to git.

# === Model Providers ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GOOGLE_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...

# === Telegram Bot Tokens ===
# Each agent gets its own bot token for Telegram gateway
TELEGRAM_BOT_TOKEN_NEO=your-neo-bot-token
TELEGRAM_BOT_TOKEN_MIMIR=your-mimir-bot-token
TELEGRAM_BOT_TOKEN_KACHRA=your-kachra-bot-token

# === Telegram Allowed Users ===
TELEGRAM_ALLOWED_USERS=your-telegram-user-id

# === Ollama Cloud ===
# If using Ollama Cloud, API key goes here
OLLAMA_API_KEY=

# === Agentmemory ===
# Already configured via MCP in config.yaml
# AGENTMEMORY_URL defaults to http://localhost:3111