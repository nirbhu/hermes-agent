# Hermes Agent — Sample Configuration
# Copy this to config.yaml and customize for your setup.
# Only the `model` section is required. Everything else has defaults.

model:
  default: glm-5.1:cloud          # Your default model
  provider: ollama-launch          # Your provider
  base_url: http://127.0.0.1:11434/v1
  api_key: ollama                 # Set real key in .env, not here
  context_length: 217600

providers:
  ollama-launch:
    api: http://127.0.0.1:11434/v1
    default_model: glm-5.1:cloud
    models:
      - glm-5.1:cloud
      - deepseek-v4-flash:cloud
      - gemma4:31b-cloud
      - kimi-k2.6:cloud
      - qwen3.5:cloud
    name: OllamaLaunch

# === Memory ===
memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 10000
  user_char_limit: 4000
  provider: agentmemory
  flush_min_turns: 6
  nudge_interval: 10

# === MCP Servers ===
mcp_servers:
  agentmemory:
    command: npx
    args:
      - -y
      - '@agentmemory/mcp'
    env:
      AGENTMEMORY_URL: http://localhost:3111

# === Agent settings ===
agent:
  max_turns: 90
  tool_use_enforcement: true

# === Terminal ===
terminal:
  timeout: 300

# === Compression ===
compression:
  enabled: true
  threshold: 0.50
  target_ratio: 0.20


# === Kanban (Fleet Task System) ===
# Only ONE profile should have dispatch_in_gateway: true (prevents race conditions)
# Other profiles set dispatch_in_gateway: false — they handle Telegram only
kanban:
  dispatch_in_gateway: true
  dispatch_interval_seconds: 60
  max_spawn: 1
  failure_limit: 2
  auto_decompose: false
  orchestrator_profile: "bawa-neo"
  default_assignee: "bawa-neo"
# === Vision (auxiliary model) ===
auxiliary:
  vision:
    provider: ollama-launch
    model: gemma4:31b-cloud