# Mimir Profile Environment
# Copy to ~/.hermes/profiles/mimir/.env with your actual values

# Telegram bot token (if this agent has a Telegram gateway)
# TELEGRAM_BOT_TOKEN=your-mimir-bot-token

# API_SERVER_PORT for this profile's gateway (if running as gateway)
# API_SERVER_PORT=8643

# Model overrides (if different from config.yaml)
# OpenAI and other keys inherited from main ~/.hermes/.env
