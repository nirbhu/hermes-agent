# Bawa Neo — Coordinator Profile Configuration
# Copy to ~/.hermes/profiles/bawa-neo/config.yaml and customize

model:
  default: kimi-k2.6:cloud
  provider: ollama-launch
  base_url: http://127.0.0.1:11434/v1
  api_key: ollama
  context_length: 217600

providers:
  ollama-launch:
    api: http://127.0.0.1:11434/v1
    default_model: kimi-k2.6:cloud
    models:
      - glm-5.1:cloud
      - deepseek-v4-flash:cloud
      - gemma4:31b-cloud
      - kimi-k2.6:cloud
      - qwen3.5:cloud
    name: OllamaLaunch

mcp_servers:
  agentmemory:
    command: npx
    args:
      - -y
      - '@agentmemory/mcp'
    env:
      AGENTMEMORY_URL: http://localhost:3111

memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 10000
  user_char_limit: 4000
  provider: agentmemory
  flush_min_turns: 6
  nudge_interval: 10

toolsets:
  - web
  - browser
  - terminal
  - file
  - code_execution
  - vision
  - skills
  - memory
  - session_search
  - delegation
  - cronjob
  - messaging
  - kanban
  - search
  - todo
  - clarify

agent:
  max_turns: 90
  tool_use_enforcement: true

terminal:
  timeout: 300

compression:
  enabled: true
  threshold: 0.50
  target_ratio: 0.20

auxiliary:
  vision:
    provider: ollama-launch
    model: gemma4:31b-cloud
